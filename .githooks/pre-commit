#!/bin/sh
# Verify multi-agent instruction-file wiring + size budgets before each commit.
# Enable once per clone: git config core.hooksPath .githooks
# Exits non-zero on failure OR after an auto-repair (stage the repair, commit again).
before="$(git status --porcelain=v1)"

python3 scripts/docreview.py || exit $?

after="$(git status --porcelain=v1)"
if [ "$before" != "$after" ]; then
  echo "docreview changed the working tree; stage the repair and commit again."
  git status --short
  exit 1
fi

# --- Non-blocking structural heads-up on the staged changes ---------------------
# Runs only after the docreview gate above passes. NEVER add an exit/threshold
# here: codebase-audit is signal, not a gate (see its SKILL.md). It always
# exits 0 so it can flag a touched outlier without ever stopping a commit.
python3 .claude/skills/codebase-audit/scripts/audit.py --staged 2>/dev/null || true
